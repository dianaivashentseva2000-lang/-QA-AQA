public class Main {
    public static boolean checkSum(int a, int b) {
        int sum = a + b;
        return sum >= 10 && sum <= 20;
    }

    public static void main(String[] args) {
        System.out.println(checkSum(5, 7));   // true  (сумма = 12)
        System.out.println(checkSum(3, 4));   // false (сумма = 7)
        System.out.println(checkSum(10, 10)); // false (сумма = 20... нет, true!)
        System.out.println(checkSum(1, 1));   // false (сумма = 2)
    }
}
