import java.util.Arrays;

public class Main {
    public static void main(String[] args) {
        int n = 5;
        int[][] array = new int[n][n];

        // Заполняем главную диагональ единицами
        for (int i = 0; i < n; i++) {
            array[i][i] = 1;
        }

        // Вывод массива
        for (int i = 0; i < n; i++) {
            System.out.println(Arrays.toString(array[i]));
        }
    }
}
